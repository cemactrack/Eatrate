# Client-safe environment variables (prefixed with EXPO_PUBLIC_)
# These variables are embedded in the client bundle and are publicly accessible

# API Base URL for your backend
EXPO_PUBLIC_API_URL=https://api.eatrate.app

# Supabase Configuration
# Client-side keys (exposed to the client)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-side keys (NOT exposed to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Development environment
NODE_ENV=development